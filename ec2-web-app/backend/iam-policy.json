{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendContactFormEmails",
      "Effect": "Allow",
      "Action": ["ses:SendEmail", "ses:SendRawEmail"],
      "Resource": "*"
    },
    {
      "Sid": "ReadAppEnvFromSSM",
      "Effect": "Allow",
      "Action": ["ssm:GetParameter", "ssm:GetParameters"],
      "Resource": "arn:aws:ssm:*:*:parameter/ec2-web-app/*"
    }
  ]
}
