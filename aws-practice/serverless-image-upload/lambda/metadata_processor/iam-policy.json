{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "MetadataProcessorS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::image-storage-932930471443-us-east-1-an/uploads/*"
    },
    {
      "Sid": "MetadataProcessorDynamoDbAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:PutItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:932930471443:table/ImageMetadata"
    }
  ]
}
