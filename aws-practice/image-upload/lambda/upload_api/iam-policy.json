{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "UploadApiS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::image-storage-932930471443-us-east-1-an/uploads/*"
    },
    {
      "Sid": "UploadApiDynamoDbAccess",
      "Effect": "Allow",
      "Action": [
        "dynamodb:Scan"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:932930471443:table/ImageMetadata"
    }
  ]
}
